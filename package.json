{
  "name": "rl-performance-lab",
  "private": true,
  "version": "2.8.0",
  "description": "RL Performance Lab - Stats API host fallback and non-empty training pack templates.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.cjs --dev\"",
    "electron:build": "npm run build:electron && electron-builder --win",
    "electron:pack": "npm run build:electron && electron-builder --dir",
    "build:electron": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build --base ./",
    "electron:rebuild": "npm install --no-audit --no-fund && npm run electron:dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwindcss": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.rlp.performancelab",
    "productName": "RL Performance Lab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "RL-Performance-Lab-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
